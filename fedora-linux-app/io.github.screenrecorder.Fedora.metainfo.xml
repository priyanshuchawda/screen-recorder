<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.screenrecorder.Fedora</id>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>Fedora Screen Recorder</name>
  <summary>A simple Wayland-safe screen recorder</summary>
  <description>
    <p>Records a selected screen or window to MP4 using the GNOME ScreenCast portal, PipeWire, and GStreamer.</p>
  </description>
  <launchable type="desktop-id">io.github.screenrecorder.Fedora.desktop</launchable>
  <provides><binary>fedora-screen-recorder</binary></provides>
  <url type="homepage">https://screen-recorder-windows.netlify.app</url>
  <developer_name>ScreenRecorder</developer_name>
  <content_rating type="oars-1.1"/>
  <releases>
    <release version="0.1.5" date="2026-07-21">
      <description>
        <p>Keeps the live camera preview at 720p and 30 FPS independently of Battery Saver.</p>
      </description>
    </release>
    <release version="0.1.4" date="2026-07-21">
      <description>
        <p>Keeps the live camera preview visible while recording, sharing one camera capture with picture-in-picture.</p>
      </description>
    </release>
    <release version="0.1.3" date="2026-07-16">
      <description>
        <p>Uses the compact movable camera preview as the default.</p>
      </description>
    </release>
    <release version="0.1.2" date="2026-07-16">
      <description>
        <p>Improves Fedora installation, GNOME launcher integration, and taskbar pinning guidance.</p>
      </description>
    </release>
  </releases>
</component>
